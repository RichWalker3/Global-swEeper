# Anthropic API Key (required)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api...

# Optional: Anthropic model to use (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: Max tokens for LLM response
# MAX_TOKENS=8192

# Jira/Confluence credentials (for later integration)
# These are also stored in ~/.workflow_mcp/jira_config.json
# JIRA_EMAIL=richie.walker@global-e.com
# JIRA_API_TOKEN=...
# JIRA_BASE_URL=https://global-e.atlassian.net

# Rename this file to .env after filling in values

