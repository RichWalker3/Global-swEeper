# Global-swEep Environment Variables
# ===================================
#
# OPTIONAL: The app runs without this file (defaults: localhost:3847, no proxy).
# Create a copy named .env only when you need one of the settings below.

# Port (optional - defaults to 3000 in Docker, 3847 locally)
# PORT=3000

# Feedback form (free at https://web3forms.com - 250 emails/month)
# After signup, update the access key in src/web/public/index.html
# Look for: const FEEDBACK_ACCESS_KEY = 'YOUR_ACCESS_KEY_HERE';

# Base URL (optional - set when hosted, falls back to localhost:PORT)
# Used for CORS and display purposes
# BASE_URL=https://your-app.railway.app

# Allowed origins for CORS (optional - comma-separated, defaults to *)
# Set this to your domain when hosted for security
# ALLOWED_ORIGINS=https://your-app.railway.app,https://your-other-domain.com

# Anthropic API Key (optional - for future Claude integration)
# Get yours at https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-api...

# Residential proxy (optional - reduces bot detection)
# Format: http://username:password@proxy-host:port
# PROXY_URL=http://user:pass@proxy.example.com:8080

# To use any of the above: copy this file to .env and uncomment/edit lines you need.

